# 🔑 توكن البوت (مطلوب) — احصل عليه من @BotFather
BOT_TOKEN=ضع_التوكن_هنا

# 👤 Chat ID للمشرف (مطلوب للإشعارات)
# للحصول عليه: ابعث رسالة لـ @userinfobot
ADMIN_ID=ضع_chat_id_هنا

# 🙍 اسم مستخدم المشرف على تيليغرام (اختياري)
ADMIN_USERNAME=your_username
